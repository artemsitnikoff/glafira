\pard\intbl\itap1\sb250\sl280{\fs24\b
Digital Clouds
}\par

\pard\intbl\itap1\sl260{\fs18\cf1\uc0\u1053 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 , dclouds.ru}\par

{\fs18 \uc0\u1048 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 , \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1077 \uc0\u1090 }
\par\li300{
{\fs18 \uc0\u8226  \uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1077 \uc0\u1090 -\uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  (\uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 , \uc0\u1089 \uc0\u1086 \uc0\u1094 .\uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1080 , \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 -\uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1072 \uc0\u1081 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1095 \uc0\u1077 \uc0\u1077 )}
}
\par\li300{
{\fs18 \uc0\u8226  \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }
}
\par

\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1043 \uc0\u1083 \uc0\u1072 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \par}

\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  c\uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  B2B \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1082 \uc0\u1077 \uc0\u1090 \uc0\u1087 \uc0\u1083 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1072 .{\line}{\line}\uc0\u1042 \uc0\u1099 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1083  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1082  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  IAM, \uc0\u1089  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1102 \uc0\u1097 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1103  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1077 \uc0\u1081  \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1089  \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1088 \uc0\u1099 \uc0\u1090 \uc0\u1099 \uc0\u1084  \uc0\u1080 \uc0\u1089 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1099 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1076 \uc0\u1086 \uc0\u1084  (Keycloak) \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074  time-to-market \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1085 \uc0\u1072  90% \uc0\u1079 \uc0\u1072  \uc0\u1089 \uc0\u1095 \uc0\u1105 \uc0\u1090  \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072  \uc0\u1086 \uc0\u1090  \uc0\u1089 \uc0\u1072 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 .{\line}{\line}\uc0\u1042 \uc0\u1099 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1083  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1082  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1085 \uc0\u1072 \uc0\u1073 \uc0\u1083 \uc0\u1102 \uc0\u1076 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  (Prometheus/Grafana, EFK, OpenTelemetry/Jaeger ){\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  (C4-\uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1101 \uc0\u1090 \uc0\u1072 \uc0\u1087 \uc0\u1072 , \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1100  time-to-market \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1085 \uc0\u1072  15%.{\line}{\line}\uc0\u1042 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1091  \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1091 \uc0\u1083 \uc0\u1103 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1093  Architecture Review, \uc0\u1089 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1074  \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1082 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1075 \uc0\u1086 \uc0\u1074  \uc0\u1074  \uc0\u1073 \uc0\u1101 \uc0\u1082 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1077  \uc0\u1085 \uc0\u1072  10%.{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : Miro, app.diagrams.net, Confluence, Jira, GitLab Microservices, Keycloak, Docker, Kubernetes, yaml, PostgreSql, Kafka, Swagger, Prometheus/Grafana, EFK, PHP, Go, React, node.js, OpenTelemetry/Jaeger, KrakenD, GraphQL, nginx}

