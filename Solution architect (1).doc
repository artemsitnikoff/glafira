\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1077 \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1086 \uc0\u1087 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084 .{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (C4 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u8220 AS IS\uc0\u8221 {\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (C4 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \