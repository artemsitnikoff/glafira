\pard\intbl\itap1\sl280\sb60\sa60{\fs24 Solution Architect\par}

\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  IAM.{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (Archimate3 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  IAM \uc0\u8220 AS IS\uc0\u8221 {\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (Archimate3 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  IAM (\uc0\u8220 TO BE\uc0\u8221 ){\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1086 \uc0\u1090  \uc0\u8220 AS IS\uc0\u8221  \uc0\u1082  \uc0\u8220 TO BE\uc0\u8221 , \uc0\u1074 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1086 \uc0\u1089  \uc0\u1091 \uc0\u1095 \uc0\u1105 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1081  \uc0\u1084 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1091  \uc0\u1089 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080 .{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1089  \uc0\u1094 \uc0\u1080 \uc0\u1092 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1100 \uc0\u1102  {\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  (C4-\uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1085 \uc0\u1072  \uc0\u1086 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1077  DDD, \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1085 \uc0\u1077 \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1080 \uc0\u1084 \uc0\u1086  \uc0\u1084 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1100  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1083 \uc0\u1080  \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1100  time-to-market \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1085 \uc0\u1072  30%.{\line}{\line}\uc0\u1042 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1091  \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1091 \uc0\u1083 \uc0\u1103 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1093  Architecture Review, \uc0\u1089 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1074  \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1082 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1075 \uc0\u1086 \uc0\u1074  \uc0\u1074  \uc0\u1073 \uc0\u1101 \uc0\u1082 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1077  \uc0\u1085 \uc0\u1072  40% \uc0\u1079 \uc0\u1072  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1086 \uc0\u1076  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080 .{\line}{\line}\uc0\u1042 \uc0\u1099 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1083  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1072  (Golang, RabbitMq, Redis, Keycloak, PostgreSql) \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 , \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1080 \uc0\u1074  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  99,9% \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080 .{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : Miro, app.diagrams.net, MS Visio, Confluence, Jira, GitLab, UML, BPMN, Archimate3, Microservices, Keycloak, Infinispan, Envoy, Docker, Kubernetes/Rancher, yaml, PostgreSql, Oracle/Colvir, MongoDB, Redis, RabbitMq, Swagger, Prometheus/Grafana, Java, Go, node.js/javascript}

