\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1057 \uc0\u1090 \uc0\u1072 \uc0\u1088 \uc0\u1096 \uc0\u1080 \uc0\u1081  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \par}

\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1074  \uc0\u1085 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1080  B2C (\uc0\u1063 \uc0\u1072 \uc0\u1090 , \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1099 , \uc0\u171 \uc0\u1057 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1081 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u187  etc){\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  \uc0\u1085 \uc0\u1072  \uc0\u1086 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1077  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1089  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1072  DDD \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (C4-\uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ), \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1085 \uc0\u1077 \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1080 \uc0\u1084 \uc0\u1086  \uc0\u1084 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1100  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1083 \uc0\u1080  \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1100  time-to-market \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1085 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  15% - 25%.{\line}{\line}\uc0\u1042 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1086  \uc0\u1082 \uc0\u1086 \uc0\u1076 \uc0\u1091  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 , \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1074 \uc0\u1086 \uc0\u1079 \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  time-to-market \uc0\u1085 \uc0\u1072  35%.{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : Miro, app.diagrams.net, Confluence, Jira, GitLab, Microservices, domain driven design, event sourcing, event storming, \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 , Docker/Kubernetes, yaml, PostgreSql, Kafka, Swagger, MongoDb, Redis, Prometheus/Grafana, EFK, C#/.NET7}

