\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1089 \uc0\u1090  - \uc0\u1042 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1081  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1089 \uc0\u1090 \par}

\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1077 \uc0\u1079 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1072 \uc0\u1090 \uc0\u1099  \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1080  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1072  \uc0\u1055 \uc0\u1054 :{\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091  \uc0\u1074 \uc0\u1077 \uc0\u1073 -\uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1084 \uc0\u1099  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1074 \uc0\u1077 \uc0\u1073 -\uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 , \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1100  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  99,9% \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080 .{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  (Archimate3 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100 ) \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1096 \uc0\u1072 \uc0\u1092 \uc0\u1090  \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1081 \uc0\u1082 \uc0\u1093 \uc0\u1086 \uc0\u1083 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1086 \uc0\u1074 .{\line}{\line}\uc0\u1042 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1091  CI/CD \uc0\u1080  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1105 \uc0\u1088 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1074  \uc0\u1083 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1084  \uc0\u1082 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1077  MS Azure service fabric.{\line}{\line}\uc0\u1042 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1083  \uc0\u1075 \uc0\u1083 \uc0\u1091 \uc0\u1073 \uc0\u1086 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1074 \uc0\u1077 \uc0\u1073 -\uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1105 \uc0\u1084  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1082  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1091  \uc0\u1096 \uc0\u1072 \uc0\u1073 \uc0\u1083 \uc0\u1086 \uc0\u1085 \uc0\u1091  Model-View-Presenter \uc0\u1079 \uc0\u1072  \uc0\u1089 \uc0\u1095 \uc0\u1105 \uc0\u1090  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1083  time-to-market \uc0\u1085 \uc0\u1072  30-50%.{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : Sparx Enterprise Architect, Archimate3, UML, Git, Confluence, Jira, MS Azure Service Fabric, BPMN, Camunda, MS SQL Server, SSRS, SSIS, Redis, Rabbit Mq, C#, .NET, ASP.NET, REST, JSON, OData, SignalR, WebSocket, JavaScript, Ajax, XML/XSLT, WCF, Silverlight, Angular, TypeScript, ORM Microsoft EF, Linq-to-SQL, IoC/DI (Autofac, .NET), PowerShell, Unit tests (MSTest, Moq), Single Page Application, CQRS, MVVM, MVC, MVP, TeamCity, ANTLR4}

