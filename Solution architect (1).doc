\par \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  B1 \uc0\u8212  \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1081 }
\par \uc0\u1053 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1094 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  A1 \uc0\u8212  \uc0\u1053 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081 }
}\cell\row

\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell
\pard\intbl\itap1\sl260{\fs18
{\cb5\chcfpat5\chcbpat5 \uc0\u1057 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1085 \uc0\u1072 \uc0\u1103 \~\uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1052 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1099 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077 \~\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1052 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1054 \uc0\u1090 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1081 \uc0\u1095 \uc0\u1080 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1077 \~\uc0\u1087 \uc0\u1072 \uc0\u1090 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1099 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 \~\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 }  {\cb5\chcfpat5\chcbpat5 REST\~API}  {\cb5\chcfpat5\chcbpat5 Kafka}  {\cb5\chcfpat5\chcbpat5 Docker}  {\cb5\chcfpat5\chcbpat5 Kubernetes}  {\cb5\chcfpat5\chcbpat5 DevOps}  {\cb5\chcfpat5\chcbpat5 C4}  {\cb5\chcfpat5\chcbpat5 UML}  {\cb5\chcfpat5\chcbpat5 C#}  {\cb5\chcfpat5\chcbpat5 .NET}  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1077 \~\uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1048 \uc0\u1058 -\uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1052 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1085 \uc0\u1072 \uc0\u1103 \~\uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 }  {\cb5\chcfpat5\chcbpat5 ArchiMate}}\cell\row


\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1044 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 }\cell\row


\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1073 \uc0\u1086  \uc0\u1084 \uc0\u1085 \uc0\u1077 }\cell
\pard\intbl\itap1\sl260{\fs18 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088  \uc0\u1089  6+ \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1086 \uc0\u1087 \uc0\u1099 \uc0\u1090 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1084 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084  \uc0\u1074  \uc0\u1089 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1093  \uc0\u1092 \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1093 , \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1081 \uc0\u1083 , \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 . \uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102 \uc0\u1089 \uc0\u1100  \uc0\u1074  \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080  cloud-native \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 , \uc0\u1084 \uc0\u1080 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  IAM. \uc0\u1054 \uc0\u1073 \uc0\u1083 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1102  \uc0\u1086 \uc0\u1087 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1084  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1089  DevOps-\uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1080  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1077 \uc0\u1081  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 . \uc0\u1042  \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1077 \uc0\u1081 \uc0\u1096 \uc0\u1077 \uc0\u1084  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102  \uc0\u1091 \uc0\u1075 \uc0\u1083 \uc0\u1091 \uc0\u1073 \uc0\u1080 \uc0\u1090 \uc0\u1100  \uc0\u1101 \uc0\u1082 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1091  \uc0\u1074  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1077  real-time \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084  \uc0\u1080  event-driven \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 .}\cell\row



\pard}