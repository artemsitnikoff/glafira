\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3
\uc0\u1044 \uc0\u1077 \uc0\u1082 \uc0\u1072 \uc0\u1073 \uc0\u1088 \uc0\u1100  2022 \emdash  \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2024
\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u160 2 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell

