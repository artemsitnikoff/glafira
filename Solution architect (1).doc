\pard\intbl\itap1\sl280{\fs24\b \uc0\u1053 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1085 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1080 \uc0\u1089 \uc0\u1089 \uc0\u1083 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 , \uc0\u1053 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 }\par
\cell\row
\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row
\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2003}\cell
\pard\intbl\itap1\sl280{\fs24\b \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }\par
\pard\intbl\itap1\sl260{\fs18 \uc0\u1059 \uc0\u1095 \uc0\u1077 \uc0\u1073 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1081  \uc0\u1053 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1080 \uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 , \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }
\cell\row


\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row

\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell
