# =============================================================
# Глафира Рекрутёр — пример .env
# Скопируй в .env (на VPS / локально) и заполни реальными значениями.
# .env защищён .gitignore — никогда не коммить.
# =============================================================

# --- БД (postgres) ---
# Эти три читает docker-compose для инициализации postgres-контейнера:
POSTGRES_USER=glafira
POSTGRES_PASSWORD=change-me-strong-24+chars
POSTGRES_DB=glafira
# DATABASE_URL читает бек. Для compose: host=db (имя сервиса). Локально: localhost.
DATABASE_URL=postgresql+asyncpg://glafira:change-me-strong-24+chars@db:5432/glafira

# --- Аутентификация ---
# JWT_SECRET сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001

# --- AI (Глафира через OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GLAFIRA_MODEL=anthropic/claude-sonnet-4-6
# mock | real (real → 501 пока интеграция с госреестрами не реализована)
GLAFIRA_VERIFY_MODE=mock
# legacy: Anthropic SDK (не используется, оставлено для совместимости)
ANTHROPIC_API_KEY=

# --- Верификация: интернет-разведка кандидата (claude CLI + WebSearch) ---
# Вариант А (как в остальных проектах): общий токен-файл claude, который держит свежим
# ArkadyJarvis. Папку монтируем в контейнер (docker-compose.prod.yml volume) и указываем путь:
CLAUDE_TOKEN_DIR=/var/www/ArkadyJarvis/data
CLAUDE_TOKEN_FILE=/app/claude-auth/.claude_token.json
# Вариант Б (фолбэк): разовый токен из `claude setup-token` (протухает за ~8ч без рефреша).
CLAUDE_CODE_OAUTH_TOKEN=
# Пусто (ни файл, ни env) → разведка не идёт, блоки честно «не настроена». Контакты (DaData)
# и госреестр-заглушки работают без токена.
CLAUDE_CLI_PATH=claude
GLAFIRA_OSINT_MODEL=opus
# Разведка идёт в фоне (не блокирует запрос) — таймаут с запасом на 4 платформы + упоминания.
GLAFIRA_OSINT_TIMEOUT=120

# --- Источники (hh / Avito) ---
HH_CLIENT_ID=
HH_CLIENT_SECRET=
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

# --- Шифрование токенов интеграций ---
# Сгенерируй: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Деплой ---
# Список origin'ов фронта через запятую. Локально: http://localhost:5173
# На проде: https://ats.yourdomain.ru
CORS_ORIGINS=http://localhost:5173
# На HTTPS-проде поставь True, чтобы refresh-cookie уходила только по HTTPS.
SESSION_COOKIE_SECURE=False

# --- Frontend (build-time, читает Vite при сборке) ---
# Локально: http://localhost:8000/api/v1
# На проде: https://ats.yourdomain.ru/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
